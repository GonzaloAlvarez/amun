#!/bin/bash
''':'
# vim: set filetype=python :
for name in python3 python; do
    if type "$name" >/dev/null 2>&1; then
        [[ -f "$0" ]] && exec "$name" "$0" "$@"
        [[ -t 0 ]] && cat <"$0" > "$HOME/.bt" || cat > "$HOME/.bt"
        { printf "\'\'\'\n" ; cat "$HOME/.bt"; } > "$HOME/.amun" && rm -f "$HOME/.bt"
        exec "$name" "$HOME/.amun" "$@"
    fi
done
echo "Please install python"
exit 1
':'''

import os, sys, signal, subprocess, socket, shutil, pathlib
from urllib.request import urlretrieve

# Tear down everything we ever wrote, on any exit path. SIGINT becomes
# KeyboardInterrupt (covered by finally); SIGTERM does not, so promote it.
signal.signal(signal.SIGTERM, lambda *_: sys.exit(1))

PROVISIONING = pathlib.Path.home() / ".provisioning"

def _cleanup():
    shutil.rmtree(PROVISIONING, ignore_errors=True)
    for shim in (pathlib.Path.home() / ".amun", pathlib.Path.home() / ".bt"):
        try:
            shim.unlink()
        except FileNotFoundError:
            pass

in_venv = (hasattr(sys, 'real_prefix') or (hasattr(sys, 'base_prefix') and sys.base_prefix != sys.prefix))
try:
    socket.create_connection(("8.8.8.8", 53), 2)
except:
    raise Exception("I couldn't reach internet. I need to bail out")

venv = PROVISIONING / ".venv"

if not in_venv:
    # Fresh slate every run: nothing amun-related survives across invocations.
    shutil.rmtree(PROVISIONING, ignore_errors=True)
    PROVISIONING.mkdir(parents=True, exist_ok=True)
    try:
        print('Retrieving virtualenv...')
        urlretrieve("https://bootstrap.pypa.io/virtualenv.pyz", str(PROVISIONING / "virtualenv.pyz"))
        subprocess.run(f'"{sys.executable}" "{PROVISIONING / "virtualenv.pyz"}" "{venv}"', shell=True, check=True)
        os.remove(str(PROVISIONING / "virtualenv.pyz"))
        subprocess.run(f'"{venv}/bin/python" -m pip install --upgrade pip setuptools wheel paramiko', shell=True, check=True)
        subprocess.run(f'"{venv}/bin/python" -m pip install dulwich --config-settings "--build-option=--pure"', shell=True, check=True)
        subprocess.run(f'"{venv}/bin/python" -m pip install --upgrade ansible', shell=True, check=True)
    except BaseException:
        _cleanup()
        raise
    os.execv(f'{venv}/bin/python', [f'{venv}/bin/python'] + sys.argv)
    sys.exit(0)

import dulwich.porcelain

try:
    repo_name = f"amun-{sys.argv[1]}" if len(sys.argv) > 1 else "amun"
    target = PROVISIONING / repo_name
    if os.getenv('AMUN_REPO'):
        shutil.copytree(os.getenv('AMUN_REPO'), target)
    else:
        dulwich.porcelain.clone(f"https://github.com/GonzaloAlvarez/{repo_name}.git", target)

    if (target / "requirements.yml").exists():
        subprocess.run(f'"{venv}/bin/ansible-galaxy" install -r requirements.yml', shell=True, check=True, cwd=str(target))

    ask_sudo = ""
    if len(sys.argv) <= 1:
        # Invalidate the cached sudo timestamp first so the probe answers the
        # sudoers policy, not whatever happens to be cached from a prior `sudo`
        # in this shell. Without -k, `sudo -n true` can pass on a stale cache
        # while Ansible's no-TTY become subprocess later fails with
        # "sudo: a password is required".
        subprocess.run(["sudo", "-k"], check=False, stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)
        try:
            subprocess.run(["sudo", "-n", "true"], check=True, stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)
        except subprocess.CalledProcessError:
            ask_sudo = "-K"

    # Run modules under the venv's OWN python, not a discovered system one.
    # With --connection=local, ansible_python_interpreter=auto_silent makes
    # AnsiballZ execute every module under a discovered system interpreter. If
    # that interpreter has its own (stale/partial) ansible-core, the module
    # serializes its result with a different ansible-core than this venv's
    # controller deserializes with -> "Module result deserialization failed:
    # Unknown profile name 'module_legacy_m2c'". Pinning the interpreter to the
    # venv python guarantees module side == controller side == one ansible-core.
    # PYTHONPATH is stripped for the same reason: it must not leak an ambient
    # ansible onto the venv's sys.path and shadow it.
    run_env = {k: v for k, v in os.environ.items() if k != "PYTHONPATH"}
    subprocess.run(f'"{venv}/bin/ansible-playbook" {ask_sudo} -i localhost, --connection=local --limit 127.0.0.1 -e ansible_python_interpreter="{venv}/bin/python" main.yml', shell=True, check=True, cwd=str(target), env=run_env)
finally:
    _cleanup()
